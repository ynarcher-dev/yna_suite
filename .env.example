# =============================================================================
# Y&A Suite — 루트 공통 환경변수 예시
# (yna_suite_environment_deployment.md §6, §7, §11)
#
# - 이 파일은 "공통 기본값" 참고용 템플릿이다. 실제 값은 .env.local 에 넣는다.
# - .env / .env.local / .env.*.local 은 커밋하지 않는다 (.gitignore 처리됨).
# - 앱별 값은 apps/{service}/.env.example 을 참고한다.
# - NEXT_PUBLIC_ 접두사 값은 브라우저에 노출된다. anon key 는 RLS 전제하에 공개 가능하나,
#   service role key 등 secret 에는 절대 NEXT_PUBLIC_ 을 붙이지 않는다.
# =============================================================================

# --- 앱 공통 ---
NEXT_PUBLIC_APP_ENV=local            # local | dev | staging | production

# --- Supabase (local/dev 는 앱들이 동일 프로젝트를 공유) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- 서버 전용 secret (필요한 앱에서만, NEXT_PUBLIC_ 금지) ---
# SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
