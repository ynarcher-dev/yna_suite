# =============================================================================
# Y&A Hub — apps/hub 환경변수 예시  (hub.ynarcher.co.kr, local: localhost:3000)
# (yna_suite_environment_deployment.md §8.1, §10)
# 실제 값은 apps/hub/.env.local 에 넣는다 (커밋 금지).
# =============================================================================

NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=Y&A Hub
NEXT_PUBLIC_APP_DOMAIN=hub.ynarcher.co.kr

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# 서버 전용 (Server Actions / Route Handlers). NEXT_PUBLIC_ 금지, 로그 출력 금지.
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
