NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=Y&A Work
NEXT_PUBLIC_APP_DOMAIN=work.ynarcher.co.kr

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3002/auth/callback
