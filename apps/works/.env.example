# Y&ARCHER WORKS — apps/works 환경변수 예시  (works.ynarcher.co.kr, local: localhost:3000)
# 내부 통합 앱(HUB/관리/AC/... 섹션). 실제 값은 apps/works/.env.local 에 넣는다 (커밋 금지).

NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=Y&ARCHER WORKS
NEXT_PUBLIC_APP_DOMAIN=works.ynarcher.co.kr
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# 서브도메인 간(works↔guest) SSO 세션 공유용. 미설정 시 호스트 기본값.
NEXT_PUBLIC_COOKIE_DOMAIN=
# 서버 전용 (NEXT_PUBLIC_ 접두사 금지)
SUPABASE_SERVICE_ROLE_KEY=
