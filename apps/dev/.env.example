# =============================================================================
# Y&A Dev — apps/dev 환경변수 예시  (dev.ynarcher.co.kr, local: localhost:3001)
# (yna_suite_environment_deployment.md §8.2, §10)
# 실제 값은 apps/dev/.env.local 에 넣는다 (커밋 금지).
# =============================================================================

NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_NAME=Y&A Dev
NEXT_PUBLIC_APP_DOMAIN=dev.ynarcher.co.kr

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3001/auth/callback

# 서브도메인 세션 공유용 쿠키 도메인. 운영에서만 설정(예: .ynarcher.co.kr).
# 로컬(localhost)에서는 비워 둔다.
# NEXT_PUBLIC_COOKIE_DOMAIN=.ynarcher.co.kr

# 서버 전용: 사용자 초대/생성·권한 부여에 필요 (RLS 우회 가능, 서버 전용, 로그 금지).
SUPABASE_SERVICE_ROLE_KEY=server-only-service-role-key
